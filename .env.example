# MedGuard Environment Configuration Example
# Copy this file to .env and fill in your values

# =============================================================================
# AI/ML Configuration (For Performance Optimization)
# =============================================================================

# HuggingFace Token (Optional - for faster model downloads and higher rate limits)
# Get your token from: https://huggingface.co/settings/tokens
# HF_TOKEN=your_huggingface_token_here

# Embedding Model Configuration
# EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
# EMBEDDING_DEVICE=cpu
# EMBEDDING_BATCH_SIZE=32

# =============================================================================
# API Keys (Required for full functionality)
# =============================================================================

# DeepSeek API Key (Required for AI explanations)
# Get your key from: https://platform.deepseek.com
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# =============================================================================
# Database Configuration
# =============================================================================

# ChromaDB Path (Vector Database)
# CHROMADB_PATH=./data/chromadb
# CHROMADB_COLLECTION_PREFIX=medguard_

# =============================================================================
# Debug Configuration
# =============================================================================

# Django Debug Mode (DO NOT enable in production)
# DEBUG=False
