# MedGuard AI Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

# =============================================================================
# DJANGO SETTINGS
# =============================================================================

# Generate a new secret key for production:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# DATABASE (MySQL)
# =============================================================================

DB_ENGINE=django.db.backends.mysql
DB_NAME=medguard
DB_USER=medguard_user
DB_PASSWORD=your-database-password
DB_HOST=localhost
DB_PORT=3306

# Connection pool settings (optional)
DB_CONN_MAX_AGE=60
DB_CONN_HEALTH_CHECKS=True

# =============================================================================
# VECTOR STORE (ChromaDB)
# =============================================================================

# Path to ChromaDB persistent storage
CHROMADB_PATH=./data/chromadb

# Collection prefix (useful for separating dev/prod)
CHROMADB_COLLECTION_PREFIX=medguard_

# Optional: ChromaDB server mode
# CHROMADB_HOST=localhost
# CHROMADB_PORT=8000

# =============================================================================
# EMBEDDING MODEL (BGE)
# =============================================================================

# Model to use for semantic embeddings
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# Device for embedding generation: 'cuda', 'cpu', 'mps' (Apple Silicon)
# Note: AMD GPUs require ROCm setup. Use 'cpu' if ROCm not configured.
EMBEDDING_DEVICE=cpu

# Batch size for embedding generation (reduce if OOM errors)
EMBEDDING_BATCH_SIZE=32

# =============================================================================
# DEEPSEEK API (for risk assessment)
# =============================================================================

DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Rate limiting
DEEPSEEK_MAX_REQUESTS_PER_MINUTE=60
DEEPSEEK_MAX_TOKENS=4096

# =============================================================================
# DATA PATHS
# =============================================================================

# Raw data directory (read-only)
DATA_RAW_PATH=./data/raw

# Processed data directory (intermediate outputs)
DATA_PROCESSED_PATH=./data/processed

# Logs directory
DATA_LOGS_PATH=./data/processed/processing_logs

# =============================================================================
# LOGGING
# =============================================================================

LOG_LEVEL=INFO
LOG_FILE=./logs/medguard.log

# =============================================================================
# SECURITY (Production)
# =============================================================================

# Set these in production
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
