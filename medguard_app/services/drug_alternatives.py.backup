"""
Drug Alternatives Service - Provides alternative medication recommendations
"""
import logging
from typing import List, Dict, Optional, Tuple
from dataclasses import dataclass
from apps.data_access.repositories.drug_repository import DrugRepository

logger = logging.getLogger(__name__)

@dataclass
class DrugAlternative:
    """Alternative drug recommendation"""
    name: str
    generic_name: str
    similarity_score: float
    advantages: List[str]
    considerations: List[str]
    reason: str

class DrugAlternativesService:
    """Service for finding alternative medications"""

