    def find_alternatives(self, drug_name: str, symptoms: List[str],
                         existing_medications: List[str] = None) -> List[DrugAlternative]:
        """
        Find alternative medications for the given drug

        LOOKUP ORDER (standardized):
        1. MySQL Database (source of truth)
        2. Hardcoded Fallback (deprecated, for gaps in database)

        Args:
            drug_name: Name of the current drug
            symptoms: List of symptoms being treated
            existing_medications: Current medications (for interaction checking)

        Returns:
            List of DrugAlternative objects
        """
        try:
            logger.info(f"Finding alternatives for {drug_name}")

            # Normalize drug name
            normalized_drug = self._normalize_drug_name(drug_name)

            alternatives = []

            # ========================================
            # STEP 1: MySQL DATABASE (Source of Truth)
            # ========================================
            drug = self.drug_repo.get_by_name(normalized_drug)
            if drug:
                db_alternatives = self.drug_repo.get_alternatives(drug, limit=5)
                if db_alternatives:
                    for alt_data in db_alternatives:
                        # Calculate compatibility score
                        score = self._calculate_db_compatibility_score(
                            alt_data, symptoms, existing_medications or []
                        )
                        alternative = DrugAlternative(
                            name=alt_data['name'].title(),
                            generic_name=alt_data['name'].lower(),
                            similarity_score=score,
                            advantages=alt_data.get('advantages', []),
                            considerations=alt_data.get('considerations', []),
                            reason=alt_data.get('reason', 'Database recommended alternative')
                        )
                        alternatives.append(alternative)

            # ========================================
            # STEP 2: HARDCODED FALLBACK (Deprecated)
            # ========================================
            if not alternatives:
                alternatives_data = self.alternatives_db.get(normalized_drug, [])
                for alt_data in alternatives_data:
                    score = self._calculate_compatibility_score(
                        alt_data, symptoms, existing_medications or []
                    )
                    alternative = DrugAlternative(
                        name=alt_data['name'],
                        generic_name=alt_data['generic_name'],
                        similarity_score=score,
                        advantages=alt_data['advantages'],
                        considerations=alt_data['considerations'],
                        reason=alt_data['reason']
                    )
                    alternatives.append(alternative)

            # Sort by compatibility score (descending)
            alternatives.sort(key=lambda x: x.similarity_score, reverse=True)

            # Return top 3 alternatives
            return alternatives[:3]

        except Exception as e:
            logger.error(f"Error finding alternatives for {drug_name}: {str(e)}")
            return []

    def _calculate_db_compatibility_score(self, alt_data: dict,
                                          symptoms: List[str],
                                          existing_meds: List[str]) -> float:
        """Calculate compatibility score for database alternative."""
        base_score = alt_data.get('similarity_score', 0.8)

        # Slight boost if we have advantages/considerations
        if alt_data.get('advantages'):
            base_score += 0.05
        if alt_data.get('considerations'):
            base_score -= 0.02  # Slight penalty for having warnings

        # Cap at 1.0
        return min(base_score, 1.0)

    def _normalize_drug_name(self, drug_name: str) -> str:
        """Normalize drug name to canonical form"""
        try:
            # Use existing drug repository normalization
            normalized = self.drug_repo.normalize_drug_name(drug_name)
            if normalized and 'canonical' in normalized:
                return normalized['canonical'].lower()
            return drug_name.lower().strip()
        except Exception:
            return drug_name.lower().strip()

    def _calculate_compatibility_score(self, alternative: Dict,
                                     symptoms: List[str],
                                     existing_meds: List[str]) -> float:
        """
        Calculate compatibility score for an alternative drug

        Args:
            alternative: Alternative drug data
            symptoms: Symptoms being treated
            existing_meds: Current medications

        Returns:
            Float score between 0.0 and 1.0
        """
        score = 0.8  # Base score

        try:
            # Adjust score based on symptom compatibility
            symptom_keywords = [s.lower() for s in symptoms]

            # Check for specific symptom matches
            if any('pain' in s or 'headache' in s for s in symptom_keywords):
                if 'pain relief' in ' '.join(alternative['advantages']).lower():
                    score += 0.1

            if any('inflammation' in s or 'swelling' in s for s in symptom_keywords):
                if 'anti-inflammatory' in ' '.join(alternative['advantages']).lower():
                    score += 0.1

            # Penalize for major considerations
            considerations_text = ' '.join(alternative['considerations']).lower()
            if 'bleeding' in considerations_text or 'stomach' in considerations_text:
                score -= 0.1

            # Bonus for fewer considerations
            if len(alternative['considerations']) <= 2:
                score += 0.05

            # Ensure score stays within bounds
            return max(0.0, min(1.0, score))

        except Exception as e:
            logger.error(f"Error calculating compatibility score: {str(e)}")
            return 0.5  # Default neutral score

    def get_alternative_summary(self, alternatives: List[DrugAlternative]) -> str:
        """Generate a summary of alternative recommendations"""
        if not alternatives:
            return "No suitable alternatives found for this medication."

        summary_parts = []

        for i, alt in enumerate(alternatives, 1):
            summary_parts.append(
                f"{i}. **{alt.name}** - {alt.reason}"
            )

        return " ".join(summary_parts)